    "admin:bootstrap": "node --env-file-if-exists=.env.local scripts/bootstrap-admin.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.6.1",
