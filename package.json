    "csv-parse": "^7.0.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "file-type": "^21.3.4",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
